<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Yourcampusapp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->

   <item name="fontFamily">@font/poppins_regular</item>
  <item name="colorPrimary">@color/blue</item>
    <item name="colorOnPrimary">@color/blue</item>
      <item name="colorPrimaryVariant">@color/blue</item>

   <item name="colorOnSecondary">@color/black</item>
   <item name="android:statusBarColor">@color/blue_secondary</item>     


    </style>

    <style name="Theme.Yourcampusapp" parent="Base.Theme.Yourcampusapp" />
    
    <style name="TitleText">
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="SubTitleText">
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="NormalText">
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="SmallText">
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">10sp</item>
    </style>
     <style name="CustomButton">
         <item name="android:textColor">@color/white</item>
         <item name="android:textAllCaps">false</item>
         <item name="android:layout_marginVertical">12dp</item>
     </style>
    <style name="CustomEditText">
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginVertical">8dp</item>
    </style>
</resources>